# ============================================================
# SocialAI Manager - Environment Variables
# Copy backend/.env.example to backend/.env for the API
# Copy this to frontend/.env.local for the Next.js app
# ============================================================

# ─── App ────────────────────────────────────────────────────
APP_NAME=SocialAI Manager
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-to-a-random-32-char-string
APP_URL=http://localhost:3000
DEBUG=true

# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI Providers ────────────────────────────────────────────
# PRIMARY: Google Gemini (recommended — fast and cheap)
AI_PROVIDER=gemini
AI_MODEL_GEMINI=gemini-1.5-flash
GEMINI_API_KEY=AIza...

# Fallback providers (optional)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_OPENAI=gpt-4o-mini
AI_MODEL_ANTHROPIC=claude-3-haiku-20240307

# ─── Admin Panel ─────────────────────────────────────────────
# Used to promote a user to superadmin via /admin/settings
ADMIN_SECRET_KEY=change-me-to-a-strong-random-string

# ─── Redis (Celery Queue) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Social Media APIs ───────────────────────────────────────
# Instagram / Facebook
INSTAGRAM_APP_ID=your-app-id
INSTAGRAM_APP_SECRET=your-app-secret
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret

# Twitter / X
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_BEARER_TOKEN=your-bearer-token

# LinkedIn
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret

# YouTube / Google
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret

# Pinterest
PINTEREST_APP_ID=your-app-id
PINTEREST_APP_SECRET=your-app-secret

# ─── Stripe (Payments) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ─── Twilio (WhatsApp Notifications) ─────────────────────────
# Sign up at https://www.twilio.com — enable WhatsApp Sandbox or Business API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=+14155238886   # Twilio sandbox number or your approved number

# ─── Backend API ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
