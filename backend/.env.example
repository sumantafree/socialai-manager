# Copy to .env and fill in your values

APP_NAME=SocialAI Manager
APP_ENV=development
APP_SECRET_KEY=your-secret-key-min-32-chars
DEBUG=true

BACKEND_CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── AI Providers ──────────────────────────────────────────────
# PRIMARY: Google Gemini (fast + cheap — recommended)
AI_PROVIDER=gemini
AI_MODEL_GEMINI=gemini-1.5-flash
GEMINI_API_KEY=AIza...

# Optional fallback providers
OPENAI_API_KEY=sk-...
AI_MODEL_OPENAI=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_ANTHROPIC=claude-3-haiku-20240307

# ── Admin Panel ───────────────────────────────────────────────
# Used to promote users to superadmin via /admin/settings
ADMIN_SECRET_KEY=change-me-to-a-strong-random-string

# Redis
REDIS_URL=redis://localhost:6379/0

# Twitter/X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# Instagram
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# Twilio (WhatsApp Notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=+14155238886
